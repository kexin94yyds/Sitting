{
  "name": "sit-reminder",
  "version": "1.0.0",
  "description": "电脑级久坐提醒应用，按固定间隔跳到前台并累计每日有效休息目标",
  "main": "main.js",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "electron": "electron .",
    "electron:dev": "NODE_ENV=development electron .",
    "test": "node tests/reminderState.test.js",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win"
  },
  "keywords": [
    "reminder",
    "desktop",
    "electron",
    "health",
    "productivity"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "build": {
    "appId": "com.sitreminder.app",
    "productName": "久坐提醒",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "main/**/*.js",
      "preload.js",
      "index.html",
      "rest.html",
      "favicon.png",
      "icon.svg"
    ],
    "mac": {
      "category": "public.app-category.healthcare-fitness",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "favicon.png"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "favicon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/sit-reminder.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/sit-reminder/issues"
  },
  "homepage": "https://github.com/yourusername/sit-reminder#readme"
}

